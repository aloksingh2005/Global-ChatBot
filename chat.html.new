<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Chat</title>
    <link rel="stylesheet" href="css/chat.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
    
    <style>
        /* Additional styles for online users section */
        .online-users-section {
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            margin-bottom: 15px;
            padding: 12px;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.3s ease, margin 0.3s ease;
        }
        
        .online-users-section.active {
            max-height: 200px;
            margin-bottom: 15px;
            padding: 12px;
            overflow-y: auto;
        }
        
        .online-users-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            color: #fff;
            cursor: pointer;
        }
        
        .online-users-header h3 {
            margin: 0;
            font-size: 16px;
            display: flex;
            align-items: center;
        }
        
        .online-count {
            background-color: #6a11cb;
            color: white;
            border-radius: 50%;
            min-width: 24px;
            height: 24px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 8px;
            font-size: 12px;
            padding: 0 4px;
        }
        
        .online-users-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .online-user {
            display: flex;
            align-items: center;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 5px 10px;
            font-size: 12px;
            color: white;
        }
        
        .online-user img {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            margin-right: 5px;
            object-fit: cover;
        }
    </style>
</head>

<body>
    <div class="chat-container">
        <div class="sidebar">
            <div class="user-profile">
                <div class="profile-pic" id="profile-pic">
                    <!-- User profile image will be set in JS -->
                </div>
                <p class="username" id="username">Loading...</p>
                <div class="settings-button" id="settingsButton">
                    <i class="fas fa-cog"></i>
                </div>
            </div>
            
            <!-- New: Online Users Section -->
            <div class="online-users-toggle">
                <div class="online-users-header" id="online-users-toggle">
                    <h3><i class="fas fa-users"></i> Online Users <span class="online-count" id="online-count">0</span></h3>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="online-users-section" id="online-users-section">
                    <div class="online-users-list" id="online-users-list">
                        <!-- Online users will be populated here -->
                    </div>
                </div>
            </div>
            
            <!-- The rest of your existing sidebar content -->
            <div class="room-tabs">
                <div class="tab active" data-room="global">
                    <i class="fas fa-globe"></i>
                    <span>Global</span>
                </div>
                <!-- More tabs can be added here -->
            </div>
        </div>
        
        <div class="chat-area">
            <div class="chat-header">
                <div class="current-room">
                    <i class="fas fa-globe"></i>
                    <h2>Global Chat</h2>
                </div>
                <div class="online-indicator">
                    <div class="indicator"></div>
                    <span id="online-counter">0 online</span>
                </div>
                <div class="actions">
                    <button id="info-button"><i class="fas fa-info-circle"></i></button>
                    <button id="theme-toggle"><i class="fas fa-moon"></i></button>
                </div>
            </div>
            
            <div class="messages" id="messages">
                <!-- Chat messages will be loaded here -->
                <div class="chat-loading">
                    <div class="loading-spinner"></div>
                    <p>Loading messages...</p>
                </div>
            </div>
            
            <div class="reply-container" id="reply-container">
                <div class="reply-content">
                    <div class="reply-to">
                        <span>Replying to <strong id="reply-name">Username</strong></span>
                        <div class="reply-close" id="reply-close"><i class="fas fa-times"></i></div>
                    </div>
                    <div class="reply-text" id="reply-text">Original message text</div>
                </div>
            </div>
            
            <div class="typing-indicator" id="typing-indicator">
                <span id="typing-text">Someone is typing...</span>
                <div class="typing-dots">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>
            
            <div class="input-area">
                <div class="emoji-button" id="emoji-button">
                    <i class="far fa-smile"></i>
                </div>
                <textarea id="message-input" placeholder="Type a message..."></textarea>
                <button id="send-button"><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>
    </div>
    
    <!-- Emoji Picker -->
    <div class="emoji-picker" id="emoji-picker">
        <!-- Emoji categories -->
        <div class="emoji-categories">
            <button class="emoji-category active" data-category="frequently-used"><i class="fas fa-clock"></i></button>
            <button class="emoji-category" data-category="smileys"><i class="far fa-smile"></i></button>
            <button class="emoji-category" data-category="animals"><i class="fas fa-paw"></i></button>
            <button class="emoji-category" data-category="food"><i class="fas fa-pizza-slice"></i></button>
            <button class="emoji-category" data-category="activities"><i class="fas fa-futbol"></i></button>
            <button class="emoji-category" data-category="travel"><i class="fas fa-car"></i></button>
            <button class="emoji-category" data-category="objects"><i class="fas fa-lightbulb"></i></button>
            <button class="emoji-category" data-category="symbols"><i class="fas fa-heart"></i></button>
            <button class="emoji-category" data-category="flags"><i class="fas fa-flag"></i></button>
        </div>
        
        <!-- Emoji content -->
        <div class="emoji-content">
            <!-- Emojis will be dynamically loaded here -->
        </div>
    </div>
    
    <!-- Message Context Menu -->
    <div class="message-options" id="message-options">
        <div class="option delete-option">
            <i class="fas fa-trash"></i>
            <span>Delete</span>
        </div>
        <div class="option reply-option">
            <i class="fas fa-reply"></i>
            <span>Reply</span>
        </div>
        <div class="option react-option">
            <i class="far fa-smile"></i>
            <span>React</span>
        </div>
    </div>
    
    <!-- Delete Confirmation Modal -->
    <div class="modal-overlay" id="delete-confirmation-modal">
        <div class="modal-content">
            <h3>Delete Message</h3>
            <p>Are you sure you want to delete this message?</p>
            <div class="modal-buttons">
                <button id="cancel-delete" class="cancel-btn">Cancel</button>
                <button id="confirm-delete" class="delete-btn">Delete</button>
            </div>
        </div>
    </div>
    
    <!-- Delete for Me Confirmation Modal -->
    <div class="modal-overlay" id="delete-for-me-confirmation-modal">
        <div class="modal-content">
            <h3>Remove for Me</h3>
            <p>This deleted message will be removed from your view only.</p>
            <div class="modal-buttons">
                <button id="cancel-delete-for-me" class="cancel-btn">Cancel</button>
                <button id="confirm-delete-for-me" class="delete-btn">Remove</button>
            </div>
        </div>
    </div>
    
    <!-- About Modal -->
    <div class="modal-overlay" id="about-modal">
        <div class="modal-content">
            <h3>About Global Chat</h3>
            <p>Global Chat is a real-time messaging platform that allows users to communicate instantly across the globe.</p>
            <p>Features:</p>
            <ul>
                <li>Real-time messaging</li>
                <li>Message reactions</li>
                <li>User profiles</li>
                <li>Theme customization</li>
                <li>Online indicators</li>
                <li>Reply to messages</li>
            </ul>
            <div class="modal-buttons">
                <button id="close-about" class="close-btn">Close</button>
            </div>
        </div>
    </div>
    
    <!-- Profile Settings Modal -->
    <div class="profile-settings-modal" id="profileSettingsModal">
        <div class="profile-settings-content">
            <div class="profile-settings-header">
                <h3>Profile Settings</h3>
                <button id="closeProfileBtn"><i class="fas fa-times"></i></button>
            </div>
            
            <div class="profile-pic-container" id="profilePicContainer">
                <!-- Profile picture will be set dynamically -->
                <div class="change-profile-pic">
                    <button id="changeProfilePicBtn"><i class="fas fa-camera"></i> Change</button>
                    <input type="file" id="profilePicInput" accept="image/*" style="display:none;">
                </div>
            </div>
            
            <div class="profile-info">
                <div class="profile-field">
                    <label>Username</label>
                    <div class="field-value">
                        <span id="displayUsername">Loading...</span>
                        <button id="editUsernameBtn"><i class="fas fa-pen"></i></button>
                    </div>
                </div>
                
                <div class="profile-field">
                    <label>Email</label>
                    <span id="displayEmail">Loading...</span>
                </div>
            </div>
            
            <div class="profile-settings-section">
                <h4>Appearance</h4>
                
                <div class="settings-option">
                    <label>Theme</label>
                    <div class="theme-options">
                        <button class="theme-option light-theme" data-theme="light"></button>
                        <button class="theme-option dark-theme active" data-theme="dark"></button>
                        <button class="theme-option blue-theme" data-theme="blue"></button>
                        <button class="theme-option green-theme" data-theme="green"></button>
                        <button class="theme-option purple-theme" data-theme="purple"></button>
                    </div>
                </div>
                
                <div class="settings-option">
                    <label>Accent Color</label>
                    <div class="color-options">
                        <button class="color-option active" style="background: linear-gradient(to right, #6a11cb, #2575fc);" data-color="#6a11cb"></button>
                        <button class="color-option" style="background: linear-gradient(to right, #ff416c, #ff4b2b);" data-color="#ff416c"></button>
                        <button class="color-option" style="background: linear-gradient(to right, #11998e, #38ef7d);" data-color="#11998e"></button>
                        <button class="color-option" style="background: linear-gradient(to right, #f7971e, #ffd200);" data-color="#f7971e"></button>
                        <button class="color-option" style="background: linear-gradient(to right, #4facfe, #00f2fe);" data-color="#4facfe"></button>
                    </div>
                </div>
                
                <div class="settings-option">
                    <label>Font</label>
                    <select id="font-selector">
                        <option value="'Poppins', sans-serif">Poppins</option>
                        <option value="'Open Sans', sans-serif">Open Sans</option>
                        <option value="'Roboto', sans-serif">Roboto</option>
                        <option value="'Lato', sans-serif">Lato</option>
                        <option value="'Montserrat', sans-serif">Montserrat</option>
                    </select>
                </div>
            </div>
            
            <div class="profile-settings-footer">
                <button id="logoutProfileBtn" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</button>
            </div>
        </div>
    </div>
    
    <script src="js/chat.js"></script>
</body>
</html> 